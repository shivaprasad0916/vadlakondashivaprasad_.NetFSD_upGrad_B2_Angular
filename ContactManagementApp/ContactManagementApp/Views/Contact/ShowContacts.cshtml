@model List<ContactApp.Models.ContactInfo>

@{
    ViewBag.Title = "All Contacts";
}

<!DOCTYPE html>
<html>
<head>
    <title>Contact Management</title>
</head>
<body>
    <h1> Contact Management</h1>
    <a class="btn" href="/Contact/AddContact">+ Add New Contact</a>

    @if (Model == null || Model.Count == 0)
    {
        <p>No contacts found. Add one!</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Company</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>Designation</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contact in Model)
                {
                    <tr>
                        <td>@contact.ContactId</td>
                        <td>@contact.FirstName</td>
                        <td>@contact.LastName</td>
                        <td>@contact.CompanyName</td>
                        <td>@contact.EmailId</td>
                        <td>@contact.MobileNo</td>
                        <td>@contact.Designation</td>
                        <td><a class="view-link" href="/Contact/GetContactById/@contact.ContactId">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</body>
</html>
